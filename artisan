#!/usr/bin/env php
<?php
declare(strict_types=1);

if (PHP_SAPI !== 'cli') {
    fwrite(STDERR, "Эта команда доступна только в консоли.\n");
    exit(1);
}

$command = $argv[1] ?? '';
if ($command !== 'admin:create') {
    fwrite(STDOUT, "SkyGuardian\n\nДоступные команды:\n  admin:create  Создать или заменить администратора\n");
    exit($command === '' ? 0 : 1);
}

function prompt(string $label): string {
    fwrite(STDOUT, $label);
    $value = fgets(STDIN);
    return trim($value === false ? '' : $value);
}

function secret(string $label): string {
    fwrite(STDOUT, $label);
    $stty = trim((string) shell_exec('command -v stty 2>/dev/null'));
    if ($stty !== '') {
        shell_exec('stty -echo');
    }
    $value = fgets(STDIN);
    if ($stty !== '') {
        shell_exec('stty echo');
    }
    fwrite(STDOUT, PHP_EOL);
    return rtrim($value === false ? '' : $value, "\r\n");
}

function characterLength(string $value): int {
    if (function_exists('mb_strlen')) {
        return mb_strlen($value, 'UTF-8');
    }

    $count = preg_match_all('/./us', $value, $matches);
    return $count === false ? strlen($value) : $count;
}

function applyWebReadablePermissions(string $directory, string $file): bool {
    $groupApplied = @chgrp($directory, 'www-data') && @chgrp($file, 'www-data');

    if ($groupApplied) {
        return @chmod($directory, 0750) && @chmod($file, 0640);
    }

    // Safe fallback for hosts where PHP-FPM does not use the www-data group.
    return @chmod($directory, 0755) && @chmod($file, 0644);
}

$email = prompt('Введите почту администратора: ');
if (!filter_var($email, FILTER_VALIDATE_EMAIL)) {
    fwrite(STDERR, "Ошибка: введите корректную почту.\n");
    exit(1);
}

$password = secret('Введите пароль: ');
$confirmation = secret('Повторите пароль: ');
if ($password !== $confirmation) {
    fwrite(STDERR, "Ошибка: пароли не совпадают.\n");
    exit(1);
}
$passwordLength = characterLength($password);
if ($passwordLength < 6 || $passwordLength > 20) {
    fwrite(STDERR, "Ошибка: пароль должен содержать от 6 до 20 символов.\n");
    exit(1);
}

$storageDir = __DIR__ . '/storage';
if (!is_dir($storageDir) && !mkdir($storageDir, 0750, true) && !is_dir($storageDir)) {
    fwrite(STDERR, "Ошибка: не удалось создать каталог хранения.\n");
    exit(1);
}

$data = [
    'email' => $email,
    'password_hash' => password_hash($password, PASSWORD_DEFAULT),
    'updated_at' => gmdate(DATE_ATOM),
];
$temp = $storageDir . '/admin.json.tmp';
$file = $storageDir . '/admin.json';
if (file_put_contents($temp, json_encode($data, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES), LOCK_EX) === false) {
    fwrite(STDERR, "Ошибка: не удалось сохранить администратора.\n");
    exit(1);
}
if (!rename($temp, $file)) {
    @unlink($temp);
    fwrite(STDERR, "Ошибка: не удалось завершить сохранение.\n");
    exit(1);
}
if (!applyWebReadablePermissions($storageDir, $file)) {
    fwrite(STDERR, "Ошибка: администратор создан, но не удалось настроить права доступа для сайта.\n");
    exit(1);
}
fwrite(STDOUT, "Администратор успешно создан.\n");
