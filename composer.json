{
  "name": "afu18c/skyguardian",
  "description": "SkyGuardian Telegram monitoring and publishing panel",
  "type": "project",
  "require": {
    "php": ">=8.2",
    "danog/madelineproto": "^8.0",
    "chillerlan/php-qrcode": "^5.0"
  },
  "autoload": {
    "psr-4": {
      "SkyGuardian\\": "src/"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "php-http/discovery": true
    }
  }
}
