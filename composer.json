{
  "name": "skyguardian/control-center",
  "description": "SkyGuardian v1 control center",
  "version": "1.0.0",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.3",
    "danog/madelineproto": "8.7.0"
  },
  "autoload": {
    "psr-4": {
      "SkyGuardian\\": "src/"
    }
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true,
    "allow-plugins": {
      "php-http/discovery": true
    }
  }
}
